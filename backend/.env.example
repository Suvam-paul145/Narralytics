# 🔐 Narralytics Backend Environment Variables
# Copy this file to .env and fill in your actual values

# ============================================================================
# GOOGLE OAUTH 2.0 CONFIGURATION
# ============================================================================
# Get these from Google Cloud Console → APIs & Services → Credentials
# Create OAuth 2.0 Client ID for Web Application

GOOGLE_CLIENT_ID=<YOUR_CLIENT_ID>
GOOGLE_CLIENT_SECRET=<YOUR_CLIENT_SECRET>

# OAuth redirect URI - MUST match Google Cloud Console settings
# Local development:
REDIRECT_URI=http://localhost:8000/auth/callback
# Production (update when deploying to AWS):
# REDIRECT_URI=https://your-api-gateway-url/auth/callback

# Frontend URL for CORS and OAuth redirects
# Local development:
FRONTEND_URL=http://localhost:5173
# Production (update when deploying):
# FRONTEND_URL=https://your-frontend.vercel.app

# ============================================================================
# JWT TOKEN CONFIGURATION
# ============================================================================
# Generate a secure secret key:
# python -c "import secrets; print(secrets.token_hex(32))"

JWT_SECRET=your-super-secret-jwt-key-change-this-to-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=24

# ============================================================================
# MONGODB CONFIGURATION
# ============================================================================
# Get connection string from MongoDB Atlas:
# 1. Go to MongoDB Atlas → Database → Connect
# 2. Choose "Connect your application"
# 3. Copy connection string and replace <password>

MONGODB_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/
MONGODB_DB=narralytics

# ============================================================================
# GOOGLE GEMINI AI CONFIGURATION
# ============================================================================
# Get API key from Google AI Studio:
# https://aistudio.google.com/app/apikey

GEMINI_API_KEY=AIza-your-gemini-api-key-here

# ============================================================================
# FILE STORAGE CONFIGURATION
# ============================================================================
# Local development - files stored in this directory
UPLOAD_DIR=./uploads

# ============================================================================
# AWS CONFIGURATION (Production Only)
# ============================================================================
# Leave these empty for local development
# Fill in when migrating to AWS Lambda

# AWS region for Lambda and S3
AWS_REGION=us-east-1

# S3 bucket name for file storage
# Must be globally unique
AWS_BUCKET=

# DynamoDB table for conversation history (optional)
# Can use MongoDB instead
DYNAMODB_TABLE=

# ============================================================================
# DEVELOPMENT SETTINGS
# ============================================================================
# Set to "development" for detailed error messages
# Set to "production" for security
ENVIRONMENT=development

# Enable debug logging (true/false)
DEBUG=true

# ============================================================================
# EXAMPLE FILLED VALUES (DO NOT USE THESE)
# ============================================================================
GOOGLE_CLIENT_ID=<YOUR_CLIENT_ID>
GOOGLE_CLIENT_SECRET=<YOUR_CLIENT_SECRET>
# JWT_SECRET=a1b2c3d4e5f6789012345678901234567890abcdef1234567890abcdef123456
# MONGODB_URI=mongodb+srv://narralytics_user:MySecurePassword123@cluster0.abc123.mongodb.net/
# GEMINI_API_KEY=your-gemini-api-key-here

# ============================================================================
# SETUP CHECKLIST
# ============================================================================
# □ Google Cloud Project created
# □ OAuth 2.0 credentials configured
# □ MongoDB Atlas cluster created
# □ Database user created with read/write permissions
# □ Network access configured (0.0.0.0/0 for development)
# □ Gemini API key obtained
# □ JWT secret generated (32+ characters)
# □ All values filled in above
# □ File saved as .env (not .env.example)
# □ .env added to .gitignore (never commit secrets!)

# ============================================================================
# SECURITY NOTES
# ============================================================================
# 🔒 NEVER commit this file to version control
# 🔒 Use different values for development and production
# 🔒 Rotate secrets regularly
# 🔒 Use environment-specific configurations
# 🔒 Enable 2FA on all service accounts

# ============================================================================
# TROUBLESHOOTING
# ============================================================================
# If you get "GEMINI_API_KEY is not configured":
# - Check the API key is correct and starts with "AIza"
# - Restart the server after adding the key
#
# If you get "MongoDB connection failed":
# - Verify the connection string format
# - Check the password doesn't contain special characters
# - Ensure network access allows your IP (0.0.0.0/0 for dev)
#
# If OAuth redirect fails:
# - Verify REDIRECT_URI matches Google Cloud Console exactly
# - Check FRONTEND_URL is correct
# - Ensure OAuth consent screen is configured

# ============================================================================
# PRODUCTION DEPLOYMENT
# ============================================================================
# When deploying to AWS Lambda:
# 1. Update REDIRECT_URI to your API Gateway URL
# 2. Update FRONTEND_URL to your production domain
# 3. Set AWS_REGION and AWS_BUCKET
# 4. Copy all values to Lambda environment variables
# 5. Never include .env file in deployment package